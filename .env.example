# ─────────────────────────────────────────────────────────────
# InvoiceAI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon / Supabase / local)
DATABASE_URL="postgresql://user:pass@host:5432/invoiceai"

# Random 32+ char string for signing JWTs.  Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Canonical app URL (no trailing slash)
AUTH_URL="http://localhost:3000"

# Anthropic API key for Claude AI  (https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Google OAuth (required for Google sign-in)
AUTH_GOOGLE_ID="123456.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-..."

# GitHub OAuth (optional)
AUTH_GITHUB_ID="Ov23li..."
AUTH_GITHUB_SECRET="abc123..."

# Public values (exposed to the browser)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="InvoiceAI"
